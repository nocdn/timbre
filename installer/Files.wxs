<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Fragment>
    <ComponentGroup Id="ApplicationFiles" Directory="INSTALLFOLDER">
      <!--
        Harvest the working x64 build output, not the publish folder.
        The build output carries the generated .xbf/.pri files that WinUI needs at runtime.
      -->
      <Files Include="$(AppPayloadDir)\**">
        <Exclude Files="$(AppPayloadDir)\**\*.pdb" />
        <Exclude Files="$(AppPayloadDir)\timbre.exe" />
      </Files>

      <Component Id="TimbreExecutableComponent" Guid="*">
        <File Id="TimbreExecutableFile" Source="$(AppPayloadDir)\timbre.exe" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
