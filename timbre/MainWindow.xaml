<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="timbre.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Timbre Settings">

    <Grid
        x:Name="RootGrid"
        Padding="20,20,0,10">

        <ScrollViewer>
            <StackPanel
                Margin="0,0,20,0"
                Spacing="16">
                <TextBlock
                    Text="Timbre"
                    Style="{ThemeResource TitleTextBlockStyle}" />

                <TextBlock
                    Text="Configure dictation, provider options, and transcript history."
                    TextWrapping="WrapWholeWords" />

                <StackPanel Spacing="14">
                    <TextBlock
                        Text="Dictation settings"
                        Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <ComboBox
                                    x:Name="InputDeviceComboBox"
                                    Width="420"
                                    Header="Input device"
                                    DisplayMemberPath="DisplayName"
                                    SelectionChanged="SettingsComboBox_SelectionChanged"
                                    PlaceholderText="Select a microphone" />
                                <Button
                                    x:Name="RefreshDevicesButton"
                                    Margin="0,28,0,0"
                                    Click="RefreshDevicesButton_Click"
                                    Content="Refresh" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Recording hotkey" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button
                                    x:Name="HotkeyCaptureButton"
                                    HorizontalAlignment="Left"
                                    Click="HotkeyCaptureButton_Click" />
                                <Button
                                    x:Name="ResetHotkeyButton"
                                    Click="ResetHotkeyButton_Click"
                                    Content="Reset to default" />
                            </StackPanel>
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Click the button, then press the new hotkey. Enter and Esc are ignored."
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Paste last transcript hotkey" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button
                                    x:Name="PasteLastTranscriptHotkeyCaptureButton"
                                    HorizontalAlignment="Left"
                                    Click="PasteLastTranscriptHotkeyCaptureButton_Click" />
                                <Button
                                    x:Name="ResetPasteLastTranscriptHotkeyButton"
                                    Click="ResetPasteLastTranscriptHotkeyButton_Click"
                                    Content="Reset to default" />
                            </StackPanel>
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="This hotkey pastes the latest completed transcript into the active text field."
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <TextBlock
                            x:Name="HotkeyWarningTextBlock"
                            Foreground="DarkOrange"
                            TextWrapping="WrapWholeWords"
                            Visibility="Collapsed" />

                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBox
                                    x:Name="TranscriptHistoryLimitTextBox"
                                    Width="160"
                                    Header="Save transcript history" />
                                <Button
                                    x:Name="SaveTranscriptHistoryLimitButton"
                                    Margin="0,28,0,0"
                                    Click="SaveTranscriptHistoryLimitButton_Click"
                                    Content="Save" />
                                <TextBlock
                                    x:Name="TranscriptHistoryLimitSavedTextBlock"
                                    Margin="0,34,0,0"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="Saved"
                                    Visibility="Collapsed" />
                            </StackPanel>
                            <TextBlock
                                x:Name="TranscriptHistoryLimitDescriptionTextBlock"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Maximum transcripts to keep on disk. The oldest entries are removed first."
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <ToggleSwitch
                                x:Name="PushToTalkToggle"
                                Toggled="PushToTalkToggle_Toggled"
                                Header="Push to talk" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="When on, the app records while the hotkey is held. When off, press once to start and once to stop."
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock
                                Text="Provider"
                                Style="{ThemeResource SubtitleTextBlockStyle}" />
                            <StackPanel Spacing="4">
                                <RadioButton
                                    x:Name="GroqProviderRadioButton"
                                    Checked="ProviderRadioButton_Checked"
                                    Content="Groq"
                                    GroupName="ProviderGroup" />
                                <RadioButton
                                    x:Name="FireworksProviderRadioButton"
                                    Checked="ProviderRadioButton_Checked"
                                    Content="Fireworks"
                                    GroupName="ProviderGroup" />
                                <RadioButton
                                    x:Name="DeepgramProviderRadioButton"
                                    Checked="ProviderRadioButton_Checked"
                                    Content="Deepgram"
                                    GroupName="ProviderGroup" />
                                <RadioButton
                                    x:Name="MistralProviderRadioButton"
                                    Checked="ProviderRadioButton_Checked"
                                    Content="Mistral"
                                    GroupName="ProviderGroup" />
                                <RadioButton
                                    x:Name="CohereProviderRadioButton"
                                    Checked="ProviderRadioButton_Checked"
                                    Content="Cohere"
                                    GroupName="ProviderGroup" />
                                <RadioButton
                                    x:Name="ElevenLabsProviderRadioButton"
                                    Checked="ProviderRadioButton_Checked"
                                    Content="ElevenLabs"
                                    GroupName="ProviderGroup" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel
                    x:Name="GroqSettingsPanel"
                    Spacing="14">
                    <TextBlock
                        Text="Groq settings"
                        Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <StackPanel Spacing="14">
                        <PasswordBox
                            x:Name="GroqApiKeyBox"
                            PasswordChanged="SettingsPasswordBox_PasswordChanged"
                            Header="Groq API key" />

                        <ComboBox
                            x:Name="GroqModelComboBox"
                            SelectionChanged="SettingsComboBox_SelectionChanged"
                            Header="Groq model"
                            PlaceholderText="Select a Groq model" />

                        <StackPanel Spacing="6">
                            <TextBox
                                x:Name="GroqLanguageTextBox"
                                Width="160"
                                HorizontalAlignment="Left"
                                Header="Language"
                                TextChanged="SettingsTextBox_TextChanged"
                                PlaceholderText="auto" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Use ISO-639-1 or ISO-639-3 code.&#x0a;Setting 'auto', the provider will detect it.&#x0a;If left blank, defaults to 'auto'"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel
                    x:Name="FireworksSettingsPanel"
                    Spacing="14">
                    <TextBlock
                        Text="Fireworks settings"
                        Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <StackPanel Spacing="14">
                        <PasswordBox
                            x:Name="FireworksApiKeyBox"
                            PasswordChanged="SettingsPasswordBox_PasswordChanged"
                            Header="Fireworks API key" />

                        <ComboBox
                            x:Name="FireworksModelComboBox"
                            SelectionChanged="SettingsComboBox_SelectionChanged"
                            Header="Fireworks model"
                            PlaceholderText="Select a Fireworks model" />

                        <StackPanel Spacing="6">
                            <TextBox
                                x:Name="FireworksLanguageTextBox"
                                Width="160"
                                HorizontalAlignment="Left"
                                Header="Language"
                                TextChanged="SettingsTextBox_TextChanged"
                                PlaceholderText="auto" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Use ISO-639-1 or ISO-639-3 code.&#x0a;Setting 'auto', the provider will detect it.&#x0a;If left blank, defaults to 'auto'"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel
                    x:Name="DeepgramSettingsPanel"
                    Spacing="14">
                    <TextBlock
                        Text="Deepgram settings"
                        Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <StackPanel Spacing="14">
                        <PasswordBox
                            x:Name="DeepgramApiKeyBox"
                            PasswordChanged="SettingsPasswordBox_PasswordChanged"
                            Header="Deepgram API key" />

                        <ToggleSwitch
                            x:Name="DeepgramStreamingToggle"
                            Header="Streaming"
                            Toggled="DeepgramStreamingToggle_Toggled" />

                        <ComboBox
                            x:Name="DeepgramModelComboBox"
                            SelectionChanged="SettingsComboBox_SelectionChanged"
                            Header="Deepgram model"
                            PlaceholderText="Select a Deepgram model" />

                        <StackPanel
                            x:Name="DeepgramVadSilenceThresholdPanel"
                            Spacing="6">
                            <NumberBox
                                x:Name="DeepgramVadSilenceThresholdNumberBox"
                                Width="160"
                                HorizontalAlignment="Left"
                                Header="VAD silence threshold"
                                Minimum="0.5"
                                Maximum="10"
                                SmallChange="0.1"
                                SpinButtonPlacementMode="Inline"
                                ValueChanged="DeepgramVadSilenceThresholdNumberBox_ValueChanged" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Seconds of silence before streaming commits a transcript chunk."
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Streaming on pastes transcript chunks while you dictate. Streaming off pastes the final transcript after recording stops. Language is fixed to English for now."
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </StackPanel>

                <StackPanel
                    x:Name="MistralSettingsPanel"
                    Spacing="14">
                    <TextBlock
                        Text="Mistral settings"
                        Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <StackPanel Spacing="14">
                        <PasswordBox
                            x:Name="MistralApiKeyBox"
                            PasswordChanged="SettingsPasswordBox_PasswordChanged"
                            Header="Mistral API key" />

                        <ToggleSwitch
                            x:Name="MistralStreamingToggle"
                            Header="Streaming"
                            Toggled="MistralStreamingToggle_Toggled" />

                        <ComboBox
                            x:Name="MistralModelComboBox"
                            SelectionChanged="SettingsComboBox_SelectionChanged"
                            Header="Mistral model"
                            PlaceholderText="Select a Mistral model" />

                        <ComboBox
                            x:Name="MistralStreamingModeComboBox"
                            SelectionChanged="SettingsComboBox_SelectionChanged"
                            Header="Streaming cadence"
                            PlaceholderText="Select a streaming cadence">
                            <ComboBoxItem Content="Fast" />
                            <ComboBoxItem Content="Steady" />
                        </ComboBox>

                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Streaming on pastes transcript chunks while you dictate. Streaming off pastes the final transcript after recording stops. Language is fixed to English for now."
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </StackPanel>

                <StackPanel
                    x:Name="CohereSettingsPanel"
                    Spacing="14">
                    <TextBlock
                        Text="Cohere settings"
                        Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <StackPanel Spacing="14">
                        <PasswordBox
                            x:Name="CohereApiKeyBox"
                            PasswordChanged="SettingsPasswordBox_PasswordChanged"
                            Header="Cohere API key" />

                        <ComboBox
                            x:Name="CohereModelComboBox"
                            SelectionChanged="SettingsComboBox_SelectionChanged"
                            Header="Cohere model"
                            PlaceholderText="Select a Cohere model" />

                        <StackPanel Spacing="6">
                            <TextBox
                                x:Name="CohereLanguageTextBox"
                                Width="160"
                                HorizontalAlignment="Left"
                                Header="Language"
                                TextChanged="SettingsTextBox_TextChanged"
                                PlaceholderText="en" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Use ISO-639-1 or ISO-639-3 code."
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel
                    x:Name="ElevenLabsSettingsPanel"
                    Spacing="14">
                    <TextBlock
                        Text="ElevenLabs settings"
                        Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <StackPanel Spacing="14">
                        <PasswordBox
                            x:Name="ElevenLabsApiKeyBox"
                            PasswordChanged="SettingsPasswordBox_PasswordChanged"
                            Header="ElevenLabs API key" />

                        <ToggleSwitch
                            x:Name="ElevenLabsStreamingToggle"
                            Header="Streaming"
                            Toggled="ElevenLabsStreamingToggle_Toggled" />

                        <ComboBox
                            x:Name="ElevenLabsModelComboBox"
                            SelectionChanged="SettingsComboBox_SelectionChanged"
                            Header="ElevenLabs model"
                            PlaceholderText="Select an ElevenLabs model" />

                        <StackPanel
                            x:Name="ElevenLabsVadSilenceThresholdPanel"
                            Spacing="6">
                            <NumberBox
                                x:Name="ElevenLabsVadSilenceThresholdNumberBox"
                                Width="160"
                                HorizontalAlignment="Left"
                                Header="VAD silence threshold"
                                Minimum="0.3"
                                Maximum="3"
                                SmallChange="0.1"
                                SpinButtonPlacementMode="Inline"
                                ValueChanged="ElevenLabsVadSilenceThresholdNumberBox_ValueChanged" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Seconds of silence before streaming commits a transcript chunk."
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBox
                                x:Name="ElevenLabsLanguageTextBox"
                                Width="160"
                                HorizontalAlignment="Left"
                                Header="Language"
                                TextChanged="SettingsTextBox_TextChanged"
                                PlaceholderText="auto" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Use ISO-639-1 or ISO-639-3 code.&#x0a;Setting 'auto', the provider will detect it.&#x0a;If left blank, defaults to 'auto'"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel Spacing="12">
                    <TextBlock
                        Text="LLM post-processing"
                        Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="6">
                            <ToggleSwitch
                                x:Name="LlmPostProcessingToggle"
                                Header="Clean transcripts with an LLM"
                                Toggled="LlmPostProcessingToggle_Toggled" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="When on, Timbre sends the finished transcript to the selected LLM provider to remove filler words, false starts, and earlier wording that the speaker corrected."
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <StackPanel
                            x:Name="LlmPostProcessingSettingsPanel"
                            Spacing="14">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Post-processing prompt" />
                                <TextBox
                                    x:Name="LlmPostProcessingPromptTextBox"
                                    MinHeight="160"
                                    AcceptsReturn="True"
                                    TextChanged="SettingsTextBox_TextChanged"
                                    TextWrapping="Wrap" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button
                                        x:Name="ResetLlmPostProcessingPromptButton"
                                        Click="ResetLlmPostProcessingPromptButton_Click"
                                        Content="Reset to default" />
                                </StackPanel>
                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="This prompt is shared by both providers. Timbre still enforces a JSON response format internally so the cleaned transcript can be parsed reliably."
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>

                            <StackPanel Spacing="6">
                                <TextBlock
                                    Text="Provider"
                                    Style="{ThemeResource SubtitleTextBlockStyle}" />
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <RadioButton
                                        x:Name="CerebrasLlmProviderRadioButton"
                                        Checked="LlmProviderRadioButton_Checked"
                                        Content="Cerebras"
                                        GroupName="LlmProviderGroup" />
                                    <RadioButton
                                        x:Name="GroqLlmProviderRadioButton"
                                        Checked="LlmProviderRadioButton_Checked"
                                        Content="Groq"
                                        GroupName="LlmProviderGroup" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel
                    x:Name="CerebrasLlmSettingsPanel"
                    Spacing="14">
                    <TextBlock
                        Text="Cerebras LLM settings"
                        Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <StackPanel Spacing="14">
                        <PasswordBox
                            x:Name="CerebrasApiKeyBox"
                            PasswordChanged="SettingsPasswordBox_PasswordChanged"
                            Header="Cerebras API key" />

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ComboBox
                                x:Name="CerebrasModelComboBox"
                                Width="420"
                                SelectionChanged="SettingsComboBox_SelectionChanged"
                                Header="Cerebras model"
                                PlaceholderText="Select a Cerebras model" />
                            <Button
                                x:Name="FetchCerebrasModelsButton"
                                Margin="0,28,0,0"
                                Click="FetchCerebrasModelsButton_Click"
                                Content="Fetch" />
                        </StackPanel>

                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Uses Cerebras chat completions. Docs: https://inference-docs.cerebras.ai/api-reference/chat-completions and https://api.cerebras.ai/v1/models"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </StackPanel>

                <StackPanel
                    x:Name="GroqLlmSettingsPanel"
                    Spacing="14">
                    <TextBlock
                        Text="Groq LLM settings"
                        Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <StackPanel Spacing="14">
                        <PasswordBox
                            x:Name="LlmGroqApiKeyBox"
                            PasswordChanged="SettingsPasswordBox_PasswordChanged"
                            Header="Groq API key" />

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ComboBox
                                x:Name="LlmGroqModelComboBox"
                                Width="420"
                                SelectionChanged="SettingsComboBox_SelectionChanged"
                                Header="Groq model"
                                PlaceholderText="Select a Groq model" />
                            <Button
                                x:Name="FetchLlmGroqModelsButton"
                                Margin="0,28,0,0"
                                Click="FetchLlmGroqModelsButton_Click"
                                Content="Fetch" />
                        </StackPanel>

                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Uses Groq chat completions. Docs: https://console.groq.com/docs/api-reference and https://api.groq.com/openai/v1/models"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Spacing="12">
                    <TextBlock
                        Text="Launch at startup"
                        Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <StackPanel Spacing="6">
                        <ToggleSwitch
                            x:Name="LaunchAtStartupToggle"
                            Header="Launch Timbre when you sign in"
                            Toggled="LaunchAtStartupToggle_Toggled" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="When on, Timbre starts automatically after you sign in and stays in the tray until you open it."
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Spacing="12">
                    <TextBlock
                        Text="Feedback"
                        Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <StackPanel Spacing="6">
                        <ToggleSwitch
                            x:Name="SoundFeedbackToggle"
                            Header="Play sound when recording starts"
                            Toggled="SoundFeedbackToggle_Toggled" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Plays a short confirmation sound when a dictation recording begins."
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Spacing="12">
                    <TextBlock
                        Text="Transcript history"
                        Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <StackPanel Spacing="12">
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Open a separate window to search, review, copy, and delete saved transcripts."
                            TextWrapping="WrapWholeWords" />

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button
                                x:Name="OpenHistoryButton"
                                Margin="0,0,0,10"
                                Click="OpenHistoryButton_Click"
                                Content="Open history"
                                HorizontalAlignment="Left" />
                            <Button
                                x:Name="OpenHistoryHotkeyCaptureButton"
                                Margin="0,0,0,10"
                                Click="OpenHistoryHotkeyCaptureButton_Click" />
                            <Button
                                x:Name="ResetOpenHistoryHotkeyButton"
                                Margin="0,0,0,10"
                                Click="ResetOpenHistoryHotkeyButton_Click"
                                Content="Reset to default" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <TextBlock
            x:Name="StatusTextBlock"
            Margin="0,0,20,15"
            MaxWidth="520"
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom"
            Foreground="{ThemeResource TextFillColorPrimaryBrush}"
            TextWrapping="WrapWholeWords"
            Visibility="Collapsed" />

        <Button
            x:Name="CancelTranscriptionButton"
            Margin="0,0,20,15"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Click="CancelTranscriptionButton_Click"
            Content="Cancel"
            Visibility="Collapsed" />
    </Grid>
</Window>
