<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="timbre.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Timbre Settings">

    <Grid
        x:Name="RootGrid"
        Padding="20,20,0,10">

        <ScrollViewer>
            <StackPanel
                Margin="0,0,20,0"
                Spacing="16">
                <TextBlock
                    Text="Timbre"
                    Style="{ThemeResource TitleTextBlockStyle}" />

                <TextBlock
                    Text="Configure dictation, provider options, and transcript history."
                    TextWrapping="WrapWholeWords" />

                <StackPanel Spacing="14">
                    <TextBlock
                        Text="Dictation settings"
                        Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <ComboBox
                                    x:Name="InputDeviceComboBox"
                                    Width="420"
                                    Header="Input device"
                                    DisplayMemberPath="DisplayName"
                                    SelectionChanged="SettingsComboBox_SelectionChanged"
                                    PlaceholderText="Select a microphone" />
                                <Button
                                    x:Name="RefreshDevicesButton"
                                    Margin="0,28,0,0"
                                    Click="RefreshDevicesButton_Click"
                                    Content="Refresh" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Recording hotkey" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button
                                    x:Name="HotkeyCaptureButton"
                                    HorizontalAlignment="Left"
                                    Click="HotkeyCaptureButton_Click" />
                                <Button
                                    x:Name="ResetHotkeyButton"
                                    Click="ResetHotkeyButton_Click"
                                    Content="Reset to default" />
                            </StackPanel>
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Click the button, then press the new hotkey. Enter and Esc are ignored."
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="Paste last transcript hotkey" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button
                                    x:Name="PasteLastTranscriptHotkeyCaptureButton"
                                    HorizontalAlignment="Left"
                                    Click="PasteLastTranscriptHotkeyCaptureButton_Click" />
                                <Button
                                    x:Name="ResetPasteLastTranscriptHotkeyButton"
                                    Click="ResetPasteLastTranscriptHotkeyButton_Click"
                                    Content="Reset to default" />
                            </StackPanel>
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="This hotkey pastes the latest completed transcript into the active text field."
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <TextBlock
                            x:Name="HotkeyWarningTextBlock"
                            Foreground="DarkOrange"
                            TextWrapping="WrapWholeWords"
                            Visibility="Collapsed" />

                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBox
                                    x:Name="TranscriptHistoryLimitTextBox"
                                    Width="160"
                                    Header="Save transcript history" />
                                <Button
                                    x:Name="SaveTranscriptHistoryLimitButton"
                                    Margin="0,28,0,0"
                                    Click="SaveTranscriptHistoryLimitButton_Click"
                                    Content="Save" />
                                <TextBlock
                                    x:Name="TranscriptHistoryLimitSavedTextBlock"
                                    Margin="0,34,0,0"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="Saved"
                                    Visibility="Collapsed" />
                            </StackPanel>
                            <TextBlock
                                x:Name="TranscriptHistoryLimitDescriptionTextBlock"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Maximum transcripts to keep on disk. The oldest entries are removed first."
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <ToggleSwitch
                                x:Name="PushToTalkToggle"
                                Toggled="PushToTalkToggle_Toggled"
                                Header="Push to talk" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="When on, the app records while the hotkey is held. When off, press once to start and once to stop."
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <ToggleSwitch
                                x:Name="RestoreClipboardToggle"
                                Toggled="RestoreClipboardToggle_Toggled"
                                Header="Restore clipboard" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="When on, the original clipboard content is automatically restored after pasting the transcript."
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock
                                Text="Provider"
                                Style="{ThemeResource SubtitleTextBlockStyle}" />
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <RadioButton
                                    x:Name="GroqProviderRadioButton"
                                    Checked="ProviderRadioButton_Checked"
                                    Content="Groq"
                                    GroupName="ProviderGroup" />
                                <RadioButton
                                    x:Name="FireworksProviderRadioButton"
                                    Checked="ProviderRadioButton_Checked"
                                    Content="Fireworks"
                                    GroupName="ProviderGroup" />
                                <RadioButton
                                    x:Name="DeepgramProviderRadioButton"
                                    Checked="ProviderRadioButton_Checked"
                                    Content="Deepgram"
                                    GroupName="ProviderGroup" />
                                <RadioButton
                                    x:Name="MistralProviderRadioButton"
                                    Checked="ProviderRadioButton_Checked"
                                    Content="Mistral"
                                    GroupName="ProviderGroup" />
                                <RadioButton
                                    x:Name="CohereProviderRadioButton"
                                    Checked="ProviderRadioButton_Checked"
                                    Content="Cohere"
                                    GroupName="ProviderGroup" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel
                    x:Name="GroqSettingsPanel"
                    Spacing="14">
                    <TextBlock
                        Text="Groq settings"
                        Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <StackPanel Spacing="14">
                        <PasswordBox
                            x:Name="GroqApiKeyBox"
                            PasswordChanged="SettingsPasswordBox_PasswordChanged"
                            Header="Groq API key" />

                        <ComboBox
                            x:Name="GroqModelComboBox"
                            SelectionChanged="SettingsComboBox_SelectionChanged"
                            Header="Groq model"
                            PlaceholderText="Select a Groq model" />

                        <StackPanel Spacing="6">
                            <TextBox
                                x:Name="GroqLanguageTextBox"
                                Header="Language"
                                TextChanged="SettingsTextBox_TextChanged"
                                PlaceholderText="en" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Use an ISO-639-1 code like 'en'. Use 'auto' to let Groq detect it. Official docs: https://console.groq.com/docs/speech-to-text"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel
                    x:Name="FireworksSettingsPanel"
                    Spacing="14">
                    <TextBlock
                        Text="Fireworks settings"
                        Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <StackPanel Spacing="14">
                        <PasswordBox
                            x:Name="FireworksApiKeyBox"
                            PasswordChanged="SettingsPasswordBox_PasswordChanged"
                            Header="Fireworks API key" />

                        <ComboBox
                            x:Name="FireworksModelComboBox"
                            SelectionChanged="SettingsComboBox_SelectionChanged"
                            Header="Fireworks model"
                            PlaceholderText="Select a Fireworks model" />

                        <StackPanel Spacing="6">
                            <TextBox
                                x:Name="FireworksLanguageTextBox"
                                Header="Language"
                                TextChanged="SettingsTextBox_TextChanged"
                                PlaceholderText="en" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Use an ISO-639-1 code like 'en'. Use 'auto' to let Fireworks detect it. Docs: https://docs.fireworks.ai/api-reference/audio-transcriptions#language-code-and-name"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel
                    x:Name="DeepgramSettingsPanel"
                    Spacing="14">
                    <TextBlock
                        Text="Deepgram settings"
                        Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <StackPanel Spacing="14">
                        <PasswordBox
                            x:Name="DeepgramApiKeyBox"
                            PasswordChanged="SettingsPasswordBox_PasswordChanged"
                            Header="Deepgram API key" />

                        <ToggleSwitch
                            x:Name="DeepgramStreamingToggle"
                            Header="Streaming"
                            Toggled="DeepgramStreamingToggle_Toggled" />

                        <ComboBox
                            x:Name="DeepgramModelComboBox"
                            SelectionChanged="SettingsComboBox_SelectionChanged"
                            Header="Deepgram model"
                            PlaceholderText="Select a Deepgram model" />

                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="When streaming is on, Timbre uses Flux and pastes transcript chunks while you dictate. When streaming is off, Timbre uses Nova-3 and pastes the final transcript after recording stops. Language is fixed to English for now. Docs: https://developers.deepgram.com/reference/speech-to-text/listen-streaming and https://developers.deepgram.com/docs/pre-recorded-audio"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </StackPanel>

                <StackPanel
                    x:Name="MistralSettingsPanel"
                    Spacing="14">
                    <TextBlock
                        Text="Mistral settings"
                        Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <StackPanel Spacing="14">
                        <PasswordBox
                            x:Name="MistralApiKeyBox"
                            PasswordChanged="SettingsPasswordBox_PasswordChanged"
                            Header="Mistral API key" />

                        <ToggleSwitch
                            x:Name="MistralRealtimeToggle"
                            Header="Realtime"
                            Toggled="MistralRealtimeToggle_Toggled" />

                        <ComboBox
                            x:Name="MistralRealtimeModeComboBox"
                            SelectionChanged="SettingsComboBox_SelectionChanged"
                            Header="Realtime mode"
                            PlaceholderText="Select a realtime mode">
                            <ComboBoxItem Content="Fast stream" />
                            <ComboBoxItem Content="Slow stream" />
                        </ComboBox>

                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="When realtime is off, Timbre uploads the finished recording to Voxtral Mini Transcribe. When realtime is on, Timbre streams 16 kHz PCM audio to Voxtral Mini Transcribe Realtime and pastes transcript chunks live while you record. Fast stream uses a 240 ms target delay. Slow stream uses a 2400 ms target delay for steadier chunks. Docs: https://docs.mistral.ai/capabilities/audio_transcription/offline_transcription and https://docs.mistral.ai/capabilities/audio_transcription/realtime_transcription"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </StackPanel>

                <StackPanel
                    x:Name="CohereSettingsPanel"
                    Spacing="14">
                    <TextBlock
                        Text="Cohere settings"
                        Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <StackPanel Spacing="14">
                        <PasswordBox
                            x:Name="CohereApiKeyBox"
                            PasswordChanged="SettingsPasswordBox_PasswordChanged"
                            Header="Cohere API key" />

                        <ComboBox
                            x:Name="CohereModelComboBox"
                            SelectionChanged="SettingsComboBox_SelectionChanged"
                            Header="Cohere model"
                            PlaceholderText="Select a Cohere model" />

                        <StackPanel Spacing="6">
                            <TextBox
                                x:Name="CohereLanguageTextBox"
                                Header="Language"
                                TextChanged="SettingsTextBox_TextChanged"
                                PlaceholderText="en" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Text="Use an ISO-639-1 code like 'en'. Cohere requires an explicit language value. Docs: https://docs.cohere.com/reference/create-audio-transcription"
                                TextWrapping="WrapWholeWords" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel Spacing="12">
                    <TextBlock
                        Text="Launch at startup"
                        Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <StackPanel Spacing="6">
                        <ToggleSwitch
                            x:Name="LaunchAtStartupToggle"
                            Header="Launch Timbre when you sign in"
                            Toggled="LaunchAtStartupToggle_Toggled" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="When on, Timbre starts automatically after you sign in and stays in the tray until you open it."
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Spacing="12">
                    <TextBlock
                        Text="Feedback"
                        Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <StackPanel Spacing="6">
                        <ToggleSwitch
                            x:Name="SoundFeedbackToggle"
                            Header="Play sound when recording starts"
                            Toggled="SoundFeedbackToggle_Toggled" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Plays a short confirmation sound when a dictation recording begins."
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Spacing="12">
                    <TextBlock
                        Text="Transcript history"
                        Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <StackPanel Spacing="12">
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="Open a separate window to search, review, copy, and delete saved transcripts."
                            TextWrapping="WrapWholeWords" />

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button
                                x:Name="OpenHistoryButton"
                                Margin="0,0,0,10"
                                Click="OpenHistoryButton_Click"
                                Content="Open history"
                                HorizontalAlignment="Left" />
                            <Button
                                x:Name="OpenHistoryHotkeyCaptureButton"
                                Margin="0,0,0,10"
                                Click="OpenHistoryHotkeyCaptureButton_Click" />
                            <Button
                                x:Name="ResetOpenHistoryHotkeyButton"
                                Margin="0,0,0,10"
                                Click="ResetOpenHistoryHotkeyButton_Click"
                                Content="Reset to default" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <TextBlock
            x:Name="StatusTextBlock"
            Margin="0,0,20,15"
            MaxWidth="520"
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom"
            Foreground="{ThemeResource TextFillColorPrimaryBrush}"
            TextWrapping="WrapWholeWords"
            Visibility="Collapsed" />

        <Button
            x:Name="CancelTranscriptionButton"
            Margin="0,0,20,15"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Click="CancelTranscriptionButton_Click"
            Content="Cancel"
            Visibility="Collapsed" />
    </Grid>
</Window>
